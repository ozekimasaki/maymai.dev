---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => new Date(b.data.date.replace(/\./g, '-')).getTime() - new Date(a.data.date.replace(/\./g, '-')).getTime())
  .slice(0, 3);
---

<section id="blog" class="Blog">
  <div class="Blog__inner l-inner">
    <div class="Blog__header u-anime">
      <h2 class="Blog__heading">Blog</h2>
      <span class="Blog__label">{`// Blog.latest(${posts.length})`}</span>
    </div>

    <ul class="Blog__list">
      {posts.map((post, i) => (
        <li class="Blog__item u-anime" style={`--delay: ${i * .08}s;`}>
          <a href={`/blog/${post.id}/`} class="Blog__link">
            <div class="Blog__thumb">
              <img
                src={post.data.thumbnail ?? '/og-image.png'}
                alt={post.data.title}
                width="1200"
                height="630"
                loading="lazy"
              />
            </div>
            <div class="Blog__content">
              <time class="Blog__date" datetime={post.data.date.replace(/\./g, '-')}>{post.data.date}</time>
              <span class="Blog__title">{post.data.title}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="Blog__more u-anime" style="--delay: .1s;">
      <a href="/blog/" class="Blog__moreLink">View More</a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .Blog {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 80px 0 60px;
    }

    &__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 60px;

      @include mix.mq(sp) {
        margin-bottom: 40px;
      }
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 3.2rem;
      line-height: 1.5;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2rem;
      }
    }

    &__label {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      flex-shrink: 0;
    }

    &__list {
      border-top: 1px solid var(--color-border);
    }

    &__item {
      border-bottom: 1px solid var(--color-border);
    }

    &__link {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 24px 0;
      transition: opacity var(--duration-base) ease;

      @include mix.mq(sp) {
        align-items: flex-start;
        gap: 12px;
        padding: 20px 0;
      }

      @media (any-hover: hover) {
        &:hover {
          opacity: .6;
        }
      }
    }

    &__thumb {
      width: 160px;
      flex-shrink: 0;
      aspect-ratio: 1200 / 630;
      overflow: hidden;
      border: 1px solid var(--color-border);
      background-color: var(--color-bg);

      @include mix.mq(sp) {
        width: 100%;
      }

      img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }
    }

    &__content {
      min-width: 0;
    }

    &__date {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      white-space: nowrap;
      display: block;
    }

    &__title {
      display: block;
      margin-top: 4px;
      font-size: .875rem;
      line-height: 1.8;
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    &__more {
      display: flex;
      justify-content: center;
      margin-top: 48px;
    }

    &__moreLink {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 180px;
      height: 55px;
      border: 1px solid var(--color-text);
      font-size: .875rem;
      letter-spacing: .1em;
      color: var(--color-text);
      transition: background-color var(--duration-base) ease, color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          background-color: var(--color-text);
          color: var(--color-bg);
        }
      }
    }
  }
</style>
