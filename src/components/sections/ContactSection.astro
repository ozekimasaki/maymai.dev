---
const links = [
  { label: 'X (Twitter)', href: 'https://x.com/mei_999_' },
  { label: 'GitHub', href: 'https://github.com/ozekimasaki' },
];
---

<section id="contact" class="Contact">
  <div class="Contact__inner l-inner">
    <h2 class="Contact__heading">Contact</h2>
    <p class="Contact__description">おしごとのご依頼・ご相談はお気軽にどうぞ。</p>

    <div class="Contact__links">
      {links.map((link) => (
        <a
          href={link.href}
          class="Contact__link"
          target="_blank"
          rel="noopener nofollow"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .Contact {
    padding: 100px 0 120px;
    text-align: center;

    @include mix.mq(sp) {
      padding: 60px 0 80px;
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 3.2rem;
      line-height: 1.5;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2rem;
      }
    }

    &__description {
      margin-top: 16px;
      font-size: .875rem;
      line-height: 1.8;
      color: var(--color-label);
    }

    &__links {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-top: 40px;

      @include mix.mq(sp) {
        gap: 16px;
      }
    }

    &__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 160px;
      height: 55px;
      border: 1px solid var(--color-text);
      font-family: var(--font-mono);
      font-size: .8125rem;
      letter-spacing: .05em;
      color: var(--color-text);
      transition: background-color var(--duration-base) ease, color var(--duration-base) ease;

      @include mix.mq(sp) {
        min-width: 140px;
        height: 50px;
        font-size: .75rem;
      }

      @media (any-hover: hover) {
        &:hover {
          background-color: var(--color-text);
          color: var(--color-bg);
        }
      }
    }
  }
</style>
