---
const today = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---

<section id="hero" class="Hero">
  <div class="Hero__bg js-hero-bg"></div>
  <div class="Hero__inner">
    <div class="Hero__content">
      <p class="Hero__label Hero__fadeItem" style="--hero-order: 0;">// portfolio_v1.0</p>
      <h1 class="Hero__heading Hero__fadeItem" style="--hero-order: 1;">
        Code with AI,<br>
        Create for Someone.
      </h1>
      <p class="Hero__description Hero__fadeItem" style="--hero-order: 2;">
        AIの力をかりながら、<br>
        しずかで心地よいデジタル体験をつくっています。
      </p>
    </div>

    <div class="Hero__scroll Hero__fadeItem" style="--hero-order: 3;">
      <span class="Hero__scrollText">scroll</span>
      <span class="Hero__scrollLine"></span>
    </div>

    <p class="Hero__lang Hero__fadeItem" style="--hero-order: 3;">lang: ja-JP</p>

    <div class="Hero__status Hero__fadeItem" style="--hero-order: 3;">
      <p>[ status: online ]</p>
      <p>last_deploy: {today}</p>
      <p>version: 1.0.0</p>
    </div>
  </div>
</section>

<script>
  const heroBackground = document.querySelector<HTMLElement>('.js-hero-bg');
  const heroSection = heroBackground?.closest<HTMLElement>('.Hero');

  const loadHeroBackground = () => {
    window.requestAnimationFrame(() => {
      void import('../../scripts/hero-pixi-bg.ts');
    });
  };

  if (heroBackground && heroSection && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0]?.isIntersecting) return;

        observer.disconnect();
        loadHeroBackground();
      },
      { rootMargin: '200px 0px' },
    );

    observer.observe(heroSection);
  } else if (heroBackground) {
    loadHeroBackground();
  }
</script>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .Hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 60px;
    overflow: hidden;

    @include mix.mq(sp) {
      padding-top: 56px;
    }

    // ===========================================
    // Hero Background
    // ===========================================

    &__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(252, 250, 245, .96) 0%, rgba(252, 250, 245, .82) 28%, rgba(252, 250, 245, .36) 56%, rgba(252, 250, 245, .08) 100%);

      :global(.Hero__pixiCanvas) {
        display: block;
        width: 100%;
        height: 100%;
        opacity: .96;
      }

      @include mix.mq(sp) {
        background:
          linear-gradient(180deg, rgba(252, 250, 245, .92) 0%, rgba(252, 250, 245, .62) 30%, rgba(252, 250, 245, .18) 100%);
      }
    }

    &__inner {
      position: relative;
      z-index: 1;
      width: 100%;
      margin-inline: auto;
      padding-inline: 40px;
      min-height: calc(100vh - 60px);
      display: flex;
      align-items: center;

      @include mix.mq(sp) {
        padding-inline: 20px;
        min-height: calc(100vh - 56px);
      }
    }

    &__content {
      position: relative;
      padding-top: 80px;
      max-width: 34rem;
      text-shadow: 0 10px 30px rgba(252, 250, 245, .42);

      @include mix.mq(sp) {
        padding-top: 40px;
        max-width: 100%;
      }
    }

    &__label {
      font-family: var(--font-mono);
      font-size: .6875rem;
      line-height: 1.5;
      letter-spacing: .1em;
      color: var(--color-label);
      margin-bottom: 24px;
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 5rem;
      line-height: 1.2;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2.5rem;
      }
    }

    &__description {
      margin-top: 32px;
      font-family: var(--font-body);
      font-weight: 300;
      font-size: .875rem;
      line-height: 2;
      color: var(--color-text);
      opacity: .7;
      max-width: 30rem;
    }

    &__scroll {
      position: absolute;
      bottom: 0px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    &__scrollText {
      font-family: var(--font-mono);
      font-size: .625rem;
      letter-spacing: .1em;
      color: var(--color-label);
    }

    &__scrollLine {
      display: block;
      width: 1px;
      height: 80px;
      background-color: var(--color-accent);
      animation: scrollLine 3s ease infinite;
    }

    &__lang {
      position: absolute;
      bottom: 40px;
      left: 40px;
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);

      @include mix.mq(sp) {
        left: 20px;
        bottom: 24px;
      }
    }

    &__status {
      position: absolute;
      bottom: 40px;
      right: 40px;
      text-align: right;

      @include mix.mq(sp) {
        right: 20px;
        bottom: 24px;
      }

      p {
        font-family: var(--font-mono);
        font-size: .625rem;
        line-height: 1.5;
        color: var(--color-label);
      }
    }
  }

  .Hero__fadeItem {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp .8s ease forwards;
    animation-delay: calc(.3s + var(--hero-order, 0) * .15s);
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .Hero__fadeItem {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .Hero__scrollLine {
      animation: none;
      transform: scaleY(1);
      transform-origin: top;
    }
  }

  @keyframes scrollLine {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }

    50% {
      transform: scaleY(1);
      transform-origin: top;
    }

    50.1% {
      transform-origin: bottom;
    }

    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }
</style>
