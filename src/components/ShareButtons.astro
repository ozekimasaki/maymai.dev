---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="ShareButtons">
  <a
    href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
    target="_blank"
    rel="noopener nofollow"
    class="ShareButtons__btn"
    aria-label="Xでシェア"
  >
    <svg class="ShareButtons__icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
  </a>

  <a
    href={`https://social-plugins.line.me/lineit/share?url=${encodedUrl}`}
    target="_blank"
    rel="noopener nofollow"
    class="ShareButtons__btn"
    aria-label="LINEでシェア"
  >
    <svg class="ShareButtons__icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
      <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386a.63.63 0 0 1-.63-.629V8.108a.63.63 0 0 1 .63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016a.63.63 0 0 1-.63.629.626.626 0 0 1-.51-.262l-2.418-3.294v2.926a.63.63 0 0 1-.63.63.63.63 0 0 1-.63-.63V8.108a.63.63 0 0 1 .63-.63c.2 0 .381.095.51.259l2.418 3.297V8.108a.63.63 0 0 1 .63-.63.63.63 0 0 1 .63.63v4.771zm-5.741 0a.63.63 0 0 1-1.26 0V8.108a.63.63 0 0 1 1.26 0v4.771zm-2.527.629H4.856a.63.63 0 0 1-.63-.629V8.108a.63.63 0 0 1 1.26 0v4.141h1.756c.349 0 .63.283.63.63 0 .344-.282.629-.63.629zM24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
    </svg>
  </a>

  <button
    class="ShareButtons__btn js-copy-url"
    data-url={url}
    type="button"
    aria-label="URLをコピー"
  >
    <svg class="ShareButtons__icon ShareButtons__iconCopy" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
    </svg>
    <svg class="ShareButtons__icon ShareButtons__iconCheck" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12" />
    </svg>
  </button>
</div>

<style lang="scss">
  @use '../styles/foundation/mixin' as mix;

  .ShareButtons {
    display: flex;
    align-items: center;
    gap: 10px;

    &__btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid var(--color-border);
      border-radius: 50%;
      color: var(--color-label);
      transition: color var(--duration-base) ease, border-color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          color: var(--color-text);
          border-color: var(--color-text);
        }
      }
    }

    &__icon {
      flex-shrink: 0;
    }

    &__iconCheck {
      display: none;
    }

    &__btn.is-copied {
      color: var(--color-accent);
      border-color: var(--color-accent);

      .ShareButtons__iconCopy {
        display: none;
      }

      .ShareButtons__iconCheck {
        display: block;
      }
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.js-copy-url').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 1500);
      } catch {
        // clipboard API unavailable — silent fail
      }
    });
  });
</script>
