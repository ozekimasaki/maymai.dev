---
import { Image } from 'astro:assets';
import imgCharacter03 from '../../assets/images/mayproject/img_character_03.jpg';

const characters = [
  {
    id: '01',
    tabLabel: 'メイド',
    role: 'メイド長',
    roleColor: '#8b5e3c',
    name: 'エリザベス・ウィンターフォード',
    nameEn: 'Elizabeth Winterford',
    description: '館の秩序を守る完璧主義のメイド長。紅茶の淹れ方には特にこだわりがあり、配信では紅茶講座が人気。実は甘いものに目がない。',
    tags: ['#紅茶', '#完璧主義', '#メイド長', '#スイーツ'],
    specs: [
      { label: '身長', value: '168cm' },
      { label: 'イメージカラー', value: 'ロイヤルブルー' },
      { label: '好きなもの', value: '紅茶、規律、磨かれた銀食器' },
      { label: '苦手なもの', value: '予定外の出来事、虫' },
    ],
    imageColor: '#2c5282',
    number: '001',
    image: imgCharacter03,
  },
  {
    id: '02',
    tabLabel: 'お嬢様',
    role: 'お嬢様',
    roleColor: '#9b2c6b',
    name: 'シャーロット・ヴァレンティーナ',
    nameEn: 'Charlotte Valentina',
    description: '館のお嬢様で、ピアノの腕前は一級品。気まぐれな性格だが、使用人たちへの信頼は厚い。ゲーム配信では意外な負けず嫌いを見せる。',
    tags: ['#ピアノ', '#お嬢様', '#ゲーム', '#負けず嫌い'],
    specs: [
      { label: '身長', value: '158cm' },
      { label: 'イメージカラー', value: 'ローズピンク' },
      { label: '好きなもの', value: 'ピアノ、猫、ショコラ' },
      { label: '苦手なもの', value: '早起き、辛いもの' },
    ],
    imageColor: '#9b2c6b',
    number: '002',
    image: imgCharacter03,
  },
  {
    id: '03',
    tabLabel: '設備・制御管理担当',
    role: '設備・制御管理担当',
    roleColor: '#5b7a5e',
    name: 'メアリー・ブラックウッド',
    nameEn: 'Mary Blackwood',
    description: '本の虫で、好きな作品の話になると普段の物静かさが嘘のように饒舌に。朗読配信が人気で、寝落ち率が高いのは褒め言葉らしい。',
    tags: ['#読書', '#朗読', '#眼鏡', '#古典文学'],
    specs: [
      { label: '身長', value: '162cm' },
      { label: 'イメージカラー', value: 'モスグリーン' },
      { label: '好きなもの', value: '古典文学、紅茶、雨の日' },
      { label: '苦手なもの', value: '本のページを折ること、騒音' },
    ],
    imageColor: '#5B7A5E',
    number: '003',
    image: imgCharacter03,
  },
];

const defaultIdx = 2;
---

<section class="MpCharacter" id="character">
  <div class="MpCharacter__radial"></div>
  <div class="MpCharacter__inner">
    <div class="MpCharacter__header">
      <div class="MpCharacter__titleBg">CHARACTER</div>
      <div class="MpCharacter__titleWrap">
        <span class="MpCharacter__titleBar"></span>
        <div class="MpCharacter__titleGroup">
          <span class="MpCharacter__titleEn">CHARACTER</span>
          <h2 class="MpCharacter__titleJa">キャラクター紹介</h2>
        </div>
      </div>
    </div>

    <div class="MpCharacter__tabs" role="tablist" aria-label="キャラクター選択">
      {characters.map((char, i) => (
        <button
          class={`MpCharacter__tab js-mp-char-tab ${i === defaultIdx ? 'MpCharacter__tab--active' : ''}`}
          type="button"
          role="tab"
          aria-selected={i === defaultIdx ? 'true' : 'false'}
          aria-controls={`mp-char-panel-${char.id}`}
          data-index={i}
        >
          <span class="MpCharacter__tabNum">{char.id}</span>
          <span class="MpCharacter__tabLabel">{char.tabLabel}</span>
        </button>
      ))}
    </div>

    {characters.map((char, i) => (
      <div
        class={`MpCharacter__content js-mp-char-panel ${i === defaultIdx ? 'is-active' : ''}`}
        id={`mp-char-panel-${char.id}`}
        role="tabpanel"
        aria-hidden={i === defaultIdx ? 'false' : 'true'}
      >
        <div class="MpCharacter__imageWrap">
          <span class="MpCharacter__number">{char.number}</span>
          <div class="MpCharacter__imageFrame">
            <Image
              src={char.image}
              alt={char.name}
              class="MpCharacter__image"
              width={516}
              height={687}
            />
            <div class="MpCharacter__imageOverlay"></div>
          </div>
          <div class="MpCharacter__progress">
            <span class="MpCharacter__progressFill"></span>
            <span class="MpCharacter__progressDot"></span>
            <span class="MpCharacter__progressDotSm"></span>
          </div>
        </div>

        <div class="MpCharacter__profile">
          <div class="MpCharacter__roleBadge" style={`background-color: ${char.roleColor}`}>
            {char.role}
          </div>
          <h3 class="MpCharacter__name">{char.name}</h3>
          <p class="MpCharacter__nameEn">{char.nameEn}</p>
          <p class="MpCharacter__desc">{char.description}</p>

          <div class="MpCharacter__tags">
            {char.tags.map((tag) => (
              <span class="MpCharacter__tag">{tag}</span>
            ))}
          </div>

          <dl class="MpCharacter__specs">
            {char.specs.map((spec) => (
              <div class="MpCharacter__specRow">
                <dt class="MpCharacter__specLabel">{spec.label}</dt>
                <dd class="MpCharacter__specValue">{spec.value}</dd>
              </div>
            ))}
          </dl>

          <div class="MpCharacter__colorInfo">
            <span
              class="MpCharacter__colorSwatch"
              style={`background-color: ${char.imageColor}`}
            ></span>
            <span class="MpCharacter__colorText">IMAGE COLOR — {char.imageColor}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style lang="scss" is:global>
  @use '../../styles/foundation/mixin' as mix;

  .MpCharacter {
    background-color: var(--mp-color-bg-warm);
    padding: 96px 0;
    position: relative;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0;
    }

    &__radial {
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      height: 100%;
      background: radial-gradient(
        ellipse at 70% 50%,
        rgba(91, 122, 94, .06) 0%,
        transparent 60%
      );
      pointer-events: none;
    }

    &__inner {
      max-width: 1200px;
      margin-inline: auto;
      padding-inline: 64px;

      @include mix.mq(sp) {
        padding-inline: 20px;
      }
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: -12px;
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      font-weight: 500;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    // Tabs
    &__tabs {
      display: flex;
      gap: 0;
      margin-bottom: 40px;

      @include mix.mq(sp) {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }

    &__tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background-color: #fff;
      font-family: var(--mp-font-main);
      font-size: .75rem;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .7);
      white-space: nowrap;
      transition: background-color var(--duration-base) ease, color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover:not(&--active) {
          background-color: rgba(232, 115, 42, .06);
        }
      }

      &--active {
        background-color: var(--mp-color-primary);
        color: #fff;
      }
    }

    &__tabNum {
      opacity: .5;
    }

    // Content panels
    &__content {
      display: none;

      &.is-active {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        animation: mpCharFadeIn .4s ease;

        @include mix.mq(sp) {
          grid-template-columns: 1fr;
          gap: 32px;
        }
      }
    }

    @keyframes mpCharFadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    // Image side
    &__imageWrap {
      position: relative;
    }

    &__number {
      position: absolute;
      top: -24px;
      left: -16px;
      font-family: var(--mp-font-main);
      font-size: 11.25rem;
      font-weight: 400;
      letter-spacing: .08em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      z-index: 1;

      @include mix.mq(sp) {
        font-size: 5rem;
        top: -12px;
      }
    }

    &__imageFrame {
      position: relative;
      border: 1px solid var(--mp-color-border);
      background-color: #fff;
      overflow: hidden;
    }

    &__image {
      width: 100%;
      height: auto;
      display: block;
    }

    &__imageOverlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(26, 26, 46, .5) 0%,
        transparent 50%
      );
      pointer-events: none;
    }

    &__progress {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-top: 14px;
    }

    &__progressFill {
      flex: 1;
      height: 2px;
      background-color: var(--mp-color-primary);
    }

    &__progressDot {
      width: 32px;
      height: 2px;
      background-color: var(--mp-color-border);
    }

    &__progressDotSm {
      width: 16px;
      height: 2px;
      background-color: rgba(238, 232, 239, .5);
    }

    // Profile side
    &__profile {
      padding-top: 16px;
    }

    &__roleBadge {
      display: inline-block;
      padding: 3px 16px;
      font-size: .6875rem;
      letter-spacing: .1em;
      color: #fff;
    }

    &__name {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      font-weight: 500;
      letter-spacing: .12em;
      color: var(--mp-color-dark);
      margin-top: 16px;

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__nameEn {
      font-size: .75rem;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .5);
      margin-top: 8px;
    }

    &__desc {
      font-size: .875rem;
      line-height: 2.2;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .8);
      margin-top: 24px;
    }

    // Tags
    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }

    &__tag {
      display: inline-block;
      padding: 3px 12px;
      font-size: .6875rem;
      letter-spacing: .04em;
      color: var(--mp-color-primary);
      background-color: rgba(232, 115, 42, .05);
      border: 1px solid rgba(232, 115, 42, .25);
    }

    // Specs
    &__specs {
      margin-top: 24px;
      border-top: 1px solid var(--mp-color-border);
    }

    &__specRow {
      display: flex;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--mp-color-border);
    }

    &__specLabel {
      width: 120px;
      font-size: .75rem;
      letter-spacing: .1em;
      color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__specValue {
      font-size: .8125rem;
      letter-spacing: .1em;
      color: rgba(26, 26, 46, .8);
    }

    // Color info
    &__colorInfo {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
    }

    &__colorSwatch {
      width: 24px;
      height: 24px;
      border: 1px solid #fff;
      box-shadow: 0 0 12px rgba(91, 122, 94, .19);
    }

    &__colorText {
      font-size: .6875rem;
      letter-spacing: .05em;
      color: rgba(26, 26, 46, .5);
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.js-mp-char-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.js-mp-char-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.index);

      tabs.forEach((t, i) => {
        const isActive = i === idx;
        t.classList.toggle('MpCharacter__tab--active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach((p, i) => {
        const isActive = i === idx;
        p.classList.toggle('is-active', isActive);
        p.setAttribute('aria-hidden', String(!isActive));
      });
    });
  });
</script>
