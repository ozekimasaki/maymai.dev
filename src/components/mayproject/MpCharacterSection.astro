---
import { Image } from 'astro:assets';
import imgCharacter03 from '../../assets/images/mayproject/img_character_03.jpg';

const characters = [
  {
    id: '01',
    tabLabel: 'メイ',
    role: 'ハウスキーパー',
    roleColor: '#6B8E5A',
    name: '桜草メイ',
    nameEn: 'Mei Sakurakusa',
    description: 'アッシュフォード家の住み込みハウスキーパー兼ガーデナー・アシスタント。北海道出身の努力家で、失敗しても「勉強になります！」と前を向く。手仕事と対面の温かさを大切にする、屋敷の暮らしを温める存在。',
    tags: ['#園芸', '#ハーブティー', '#アナログ', '#努力型'],
    specs: [
      { label: '年齢', value: '20歳' },
      { label: '出身', value: '日本・北海道' },
      { label: '好きなもの', value: '園芸、料理、手紙、対面の会話' },
      { label: '苦手なもの', value: 'デジタル操作、人混み、雷' },
    ],
    imageColor: '#6B8E5A',
    number: '001',
    image: imgCharacter03,
  },
  {
    id: '02',
    tabLabel: 'エレナ',
    role: 'お嬢様',
    roleColor: '#7F90A6',
    name: 'エレナ・グレース・アッシュフォード',
    nameEn: 'Elena Grace Ashford',
    description: 'アッシュフォード家のお嬢様。上品で穏やか、言葉は多くないが気遣いがにじむ。写真で見たブルーポピーにずっと憧れている。静かにほどけるような優しさで、メイの努力を笑わず、安心できる言葉を返してくれる。',
    tags: ['#読書', '#ブルーポピー', '#穏やか', '#窓辺の光'],
    specs: [
      { label: '年齢', value: '20歳' },
      { label: '瞳の色', value: 'ブルーグレー' },
      { label: '好きなもの', value: '花の写真、読書、窓辺の光' },
      { label: '苦手なもの', value: '騒がしさ、人の多さ' },
    ],
    imageColor: '#7F90A6',
    number: '002',
    image: imgCharacter03,
  },
  {
    id: '03',
    tabLabel: 'アイリス',
    role: '設備・制御管理担当',
    roleColor: '#5C7E86',
    name: 'アイリス・ウェインライト',
    nameEn: 'Iris Wainwright',
    description: '屋敷の設備と制御を預かる技術者。音、光、温度の乱れを先回りで抑え、静けさを壊さずに日常を支える"調律役"。メイのアナログな手仕事の価値を理解し、その温かさをAIにも残そうとする。',
    tags: ['#設備調整', '#対話AI設計', '#静かな理知', '#調律役'],
    specs: [
      { label: '年齢', value: '25歳' },
      { label: '瞳の色', value: 'スチールグレー' },
      { label: '好きなもの', value: '設備の微調整、整備記録、静かな巡回' },
      { label: '苦手なもの', value: '自分の休息、感情を伝えること' },
    ],
    imageColor: '#5C7E86',
    number: '003',
    image: imgCharacter03,
  },
];

const defaultIdx = 0;
---

<section class="MpCharacter" id="character">
  <div class="MpCharacter__radial"></div>
  <div class="MpCharacter__inner MpGrid">
    <div class="MpCharacter__header">
      <div class="MpCharacter__titleBg">CHARACTER</div>
      <div class="MpCharacter__titleWrap">
        <span class="MpCharacter__titleBar"></span>
        <div class="MpCharacter__titleGroup">
          <span class="MpCharacter__titleEn">CHARACTER</span>
          <h2 class="MpCharacter__titleJa">キャラクター紹介</h2>
        </div>
      </div>
    </div>

    <div class="MpCharacter__tabs" role="tablist" aria-label="キャラクター選択">
      {characters.map((char, i) => (
        <button
          class={`MpCharacter__tab js-mp-char-tab ${i === defaultIdx ? 'MpCharacter__tab--active' : ''}`}
          type="button"
          role="tab"
          aria-selected={i === defaultIdx ? 'true' : 'false'}
          aria-controls={`mp-char-panel-${char.id}`}
          data-index={i}
        >
          <span class="MpCharacter__tabNum">{char.id}</span>
          <span class="MpCharacter__tabLabel">{char.tabLabel}</span>
        </button>
      ))}
    </div>

    {characters.map((char, i) => (
      <div
        class={`MpCharacter__content js-mp-char-panel ${i === defaultIdx ? 'is-active' : ''}`}
        id={`mp-char-panel-${char.id}`}
        role="tabpanel"
        aria-hidden={i === defaultIdx ? 'false' : 'true'}
      >
        <div class="MpCharacter__imageWrap">
          <span class="MpCharacter__number">{char.number}</span>
          <div class="MpCharacter__imageFrame">
            <Image
              src={char.image}
              alt={char.name}
              class="MpCharacter__image"
              width={516}
              height={687}
            />
            <div class="MpCharacter__imageOverlay"></div>
          </div>
          <div class="MpCharacter__progress">
            <span class="MpCharacter__progressFill"></span>
            <span class="MpCharacter__progressDot"></span>
            <span class="MpCharacter__progressDotSm"></span>
          </div>
        </div>

        <div class="MpCharacter__profile">
          <div class="MpCharacter__roleBadge" style={`background-color: ${char.roleColor}`}>
            {char.role}
          </div>
          <h3 class="MpCharacter__name">{char.name}</h3>
          <p class="MpCharacter__nameEn">{char.nameEn}</p>
          <p class="MpCharacter__desc">{char.description}</p>

          <div class="MpCharacter__tags">
            {char.tags.map((tag) => (
              <span class="MpCharacter__tag">{tag}</span>
            ))}
          </div>

          <dl class="MpCharacter__specs">
            {char.specs.map((spec) => (
              <div class="MpCharacter__specRow">
                <dt class="MpCharacter__specLabel">{spec.label}</dt>
                <dd class="MpCharacter__specValue">{spec.value}</dd>
              </div>
            ))}
          </dl>

          <div class="MpCharacter__colorInfo">
            <span
              class="MpCharacter__colorSwatch"
              style={`background-color: ${char.imageColor}`}
            ></span>
            <span class="MpCharacter__colorText">IMAGE COLOR — {char.imageColor}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style lang="scss" is:global>
  @use '../../styles/foundation/mixin' as mix;

  .MpCharacter {
    background-color: color-mix(in srgb, var(--mp-color-bg-warm) 95%, transparent);
    padding: 96px 0;
    position: relative;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0;
    }

    &__radial {
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      height: 100%;
      background: radial-gradient(
        ellipse at 70% 50%,
        rgba(91, 122, 94, .06) 0%,
        transparent 60%
      );
      pointer-events: none;
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
      grid-column: 1 / -1;
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: -12px;
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    // Tabs
    &__tabs {
      display: flex;
      gap: 0;
      margin-bottom: 40px;
      grid-column: 1 / -1;

      @include mix.mq(sp) {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }

    &__tab {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background-color: #fff;
      font-family: var(--mp-font-main);
      font-size: .75rem;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .8);
      white-space: nowrap;
      transition: background-color var(--duration-base) ease, color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover:not(&--active) {
          background-color: rgba(232, 115, 42, .06);
        }
      }

      &--active {
        background-color: var(--mp-color-primary);
        color: #fff;
      }
    }

    &__tabNum {
      opacity: .5;
    }

    // Content panels
    &__content {
      display: none;
      grid-column: 1 / -1;

      &.is-active {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        animation: mpCharFadeIn .4s ease;

        @include mix.mq(sp) {
          grid-template-columns: 1fr;
          gap: 32px;
        }
      }
    }

    @keyframes mpCharFadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    // Image side
    &__imageWrap {
      position: relative;
    }

    &__number {
      position: absolute;
      top: -24px;
      left: -16px;
      font-family: var(--mp-font-main);
      font-size: 11.25rem;
      font-weight: 400;
      letter-spacing: .08em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      z-index: 1;

      @include mix.mq(sp) {
        font-size: 5rem;
        top: -12px;
      }
    }

    &__imageFrame {
      position: relative;
      border: 1px solid var(--mp-color-border);
      background-color: #fff;
      overflow: hidden;
    }

    &__image {
      width: 100%;
      height: auto;
      display: block;
    }

    &__imageOverlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(26, 26, 46, .5) 0%,
        transparent 50%
      );
      pointer-events: none;
    }

    &__progress {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-top: 14px;
    }

    &__progressFill {
      flex: 1;
      height: 2px;
      background-color: var(--mp-color-primary);
    }

    &__progressDot {
      width: 32px;
      height: 2px;
      background-color: var(--mp-color-border);
    }

    &__progressDotSm {
      width: 16px;
      height: 2px;
      background-color: rgba(238, 232, 239, .5);
    }

    // Profile side
    &__profile {
      padding-top: 16px;
    }

    &__roleBadge {
      display: inline-block;
      padding: 3px 16px;
      font-size: .6875rem;
      letter-spacing: .1em;
      color: #fff;
    }

    &__name {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .12em;
      color: var(--mp-color-dark);
      margin-top: 16px;

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__nameEn {
      font-size: .75rem;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .65);
      margin-top: 8px;
    }

    &__desc {
      font-size: .875rem;
      line-height: 2.2;
      letter-spacing: .08em;
      color: rgba(26, 26, 46, .9);
      margin-top: 24px;
    }

    // Tags
    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
    }

    &__tag {
      display: inline-block;
      padding: 3px 12px;
      font-size: .6875rem;
      letter-spacing: .04em;
      color: var(--mp-color-primary);
      background-color: rgba(232, 115, 42, .05);
      border: 1px solid rgba(232, 115, 42, .25);
    }

    // Specs
    &__specs {
      margin-top: 24px;
      border-top: 1px solid var(--mp-color-border);
    }

    &__specRow {
      display: flex;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--mp-color-border);
    }

    &__specLabel {
      width: 120px;
      font-size: .75rem;
      letter-spacing: .1em;
      color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__specValue {
      font-size: .8125rem;
      letter-spacing: .1em;
      color: rgba(26, 26, 46, .9);
    }

    // Color info
    &__colorInfo {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
    }

    &__colorSwatch {
      width: 24px;
      height: 24px;
      border: 1px solid #fff;
      box-shadow: 0 0 12px rgba(91, 122, 94, .19);
    }

    &__colorText {
      font-size: .6875rem;
      letter-spacing: .05em;
      color: rgba(26, 26, 46, .65);
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.js-mp-char-tab');
  const panels = document.querySelectorAll<HTMLDivElement>('.js-mp-char-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.index);

      tabs.forEach((t, i) => {
        const isActive = i === idx;
        t.classList.toggle('MpCharacter__tab--active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach((p, i) => {
        const isActive = i === idx;
        p.classList.toggle('is-active', isActive);
        p.setAttribute('aria-hidden', String(!isActive));
      });
    });
  });
</script>
