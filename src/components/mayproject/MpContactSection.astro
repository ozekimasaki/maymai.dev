---
---

<section class="MpContact" id="contact">
  <div class="MpContact__bgText pc-only">CONTACT</div>
  <div class="MpContact__inner">
    <div class="MpContact__header">
      <div class="MpContact__titleBg">CONTACT</div>
      <div class="MpContact__titleWrap">
        <span class="MpContact__titleBar"></span>
        <div class="MpContact__titleGroup">
          <span class="MpContact__titleEn">CONTACT</span>
          <h2 class="MpContact__titleJa">お手紙</h2>
        </div>
      </div>
    </div>

    <form class="MpContact__form" action="#" method="post">
      <div class="MpContact__field">
        <label class="MpContact__label" for="mp-name">NAME</label>
        <input
          class="MpContact__input"
          type="text"
          id="mp-name"
          name="name"
          autocomplete="name"
        >
      </div>
      <div class="MpContact__field">
        <label class="MpContact__label" for="mp-email">E-MAIL</label>
        <input
          class="MpContact__input"
          type="email"
          id="mp-email"
          name="email"
          autocomplete="email"
        >
      </div>
      <div class="MpContact__field">
        <label class="MpContact__label" for="mp-message">MESSAGE</label>
        <textarea
          class="MpContact__textarea"
          id="mp-message"
          name="message"
          rows="6"
        ></textarea>
      </div>
      <button class="MpContact__submit" type="submit">SEND</button>
    </form>
  </div>
</section>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .MpContact {
    background-color: rgba(255, 255, 255, .95);
    padding: 96px 0;
    position: relative;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0;
    }

    &__bgText {
      position: absolute;
      top: 62px;
      right: 0;
      font-family: var(--mp-font-main);
      font-size: 8.75rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .03);
      writing-mode: vertical-rl;
      pointer-events: none;
      user-select: none;
    }

    &__inner {
      max-width: 560px;
      margin-inline: auto;
      padding-inline: 40px;

      @include mix.mq(sp) {
        padding-inline: 20px;
      }
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: -12px;
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__form {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    &__field {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    &__label {
      font-size: .6875rem;
      font-weight: 400;
      letter-spacing: .15em;
      color: rgba(26, 26, 46, .75);
    }

    &__input,
    &__textarea {
      width: 100%;
      padding: 12px 16px;
      background-color: #f8f6fa;
      border: none;
      border-bottom: 1px solid var(--mp-color-border);
      font-family: var(--mp-font-main);
      font-size: .875rem;
      color: var(--mp-color-dark);
      transition: border-color var(--duration-base) ease;

      &:focus {
        outline: none;
        border-bottom-color: var(--mp-color-primary);
      }
    }

    &__textarea {
      resize: vertical;
      min-height: 150px;
    }

    &__submit {
      align-self: flex-start;
      padding: 14px 48px;
      background-color: var(--mp-color-primary);
      color: #fff;
      font-family: var(--mp-font-main);
      font-size: .8125rem;
      letter-spacing: .15em;
      transition: opacity var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          opacity: .85;
        }
      }

      @include mix.mq(sp) {
        width: 100%;
        text-align: center;
      }
    }
  }
</style>
