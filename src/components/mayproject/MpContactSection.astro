---
const links = [
  {
    label: 'X (Twitter)',
    href: 'https://x.com/mei_999_',
    icon: `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'GitHub',
    href: 'https://github.com/ozekimasaki',
    icon: `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
];
---

<section class="MpContact" id="contact">
  <div class="MpContact__bgText pc-only">CONTACT</div>
  <div class="MpContact__inner MpGrid">
    <div class="MpContact__header">
      <div class="MpContact__titleBg">CONTACT</div>
      <div class="MpContact__titleWrap">
        <span class="MpContact__titleBar"></span>
        <div class="MpContact__titleGroup">
          <span class="MpContact__titleEn">CONTACT</span>
          <h2 class="MpContact__titleJa">お問い合わせ</h2>
        </div>
      </div>
    </div>

    <div class="MpContact__body">
      <p class="MpContact__description">
        ご連絡はSNSからお気軽にどうぞ。
      </p>
      <div class="MpContact__links">
        {links.map((link) => (
          <a
            href={link.href}
            class="MpContact__link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="MpContact__linkIcon" set:html={link.icon} />
            <span class="MpContact__linkLabel">{link.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .MpContact {
    background-color: rgba(255, 255, 255, .95);
    padding: 96px 0;
    position: relative;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0;
    }

    &__bgText {
      position: absolute;
      top: 62px;
      right: 0;
      font-family: var(--mp-font-main);
      font-size: 8.75rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .03);
      writing-mode: vertical-rl;
      pointer-events: none;
      user-select: none;
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
      grid-column: 1 / -1;
      padding-left: calc((100% + 16px) * 2 / 12);

      @include mix.mq(sp) {
        padding-left: 0;
      }
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: calc((100% + 16px) * 2 / 12 - 12px);
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
        left: -12px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__body {
      grid-column: 1 / -1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    &__description {
      font-family: var(--mp-font-main);
      font-size: .9375rem;
      letter-spacing: .06em;
      line-height: 1.8;
      color: rgba(26, 26, 46, .7);
      text-align: center;
    }

    &__links {
      display: flex;
      justify-content: center;
      gap: 24px;

      @include mix.mq(sp) {
        flex-direction: column;
        gap: 12px;
        width: 100%;
      }
    }

    &__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-width: 200px;
      padding: 14px 32px;
      border: 1px solid var(--mp-color-border);
      font-family: var(--mp-font-main);
      font-size: .8125rem;
      letter-spacing: .12em;
      color: var(--mp-color-dark);
      transition:
        background-color var(--duration-base) ease,
        color var(--duration-base) ease,
        border-color var(--duration-base) ease;

      @include mix.mq(sp) {
        width: 100%;
        padding: 14px 24px;
        font-size: .8125rem;
      }

      @media (any-hover: hover) {
        &:hover {
          background-color: var(--mp-color-primary);
          border-color: var(--mp-color-primary);
          color: #fff;
        }
      }
    }

    &__linkIcon {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    &__linkLabel {
      white-space: nowrap;
    }
  }
</style>
