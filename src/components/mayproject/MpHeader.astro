---
import logoSvg from '../../assets/images/mayproject/logo_mei.svg';

const navItems = [
  { en: 'ABOUT', ja: 'プロジェクトについて', href: '#about' },
  { en: 'GALLERY', ja: '画像展示室', href: '#gallery' },
  { en: 'CHARACTER', ja: 'キャラクター紹介', href: '#character' },
  { en: 'CONTACT', ja: 'お手紙', href: '#contact' },
];
---

<header class="MpHeader js-mp-header">
  <div class="MpHeader__inner">
    <a href="/mayproject/" class="MpHeader__logo">
      <img src={logoSvg.src} alt="桜草メイプロジェクト" class="MpHeader__logoImg" width="160" height="86" />
    </a>

    <nav class="MpHeader__nav pc-only" aria-label="メインナビゲーション">
      <ul class="MpHeader__navList">
        {navItems.map((item) => (
          <li class="MpHeader__navItem">
            <a href={item.href} class="MpHeader__navLink">
              <span class="MpHeader__navEn">{item.en}</span>
              <span class="MpHeader__navJa">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="MpHeader__burger sp-only js-mp-burger"
      type="button"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mp-sp-menu"
    >
      <span class="MpHeader__burgerLine"></span>
      <span class="MpHeader__burgerLine"></span>
      <span class="MpHeader__burgerLine"></span>
    </button>
  </div>

  <div class="MpHeader__menu sp-only" id="mp-sp-menu" aria-hidden="true">
    <nav aria-label="メインメニュー">
      <ul class="MpHeader__menuList">
        {navItems.map((item) => (
          <li class="MpHeader__menuItem">
            <a href={item.href} class="MpHeader__menuLink js-mp-menu-link">
              <span class="MpHeader__menuEn">{item.en}</span>
              <span class="MpHeader__menuJa">{item.ja}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .MpHeader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: var(--z-header);
    background-color: rgba(255, 255, 255, .8);
    border-bottom: 1px solid var(--mp-color-border);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 8px rgba(26, 26, 46, .06);

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 64px;
      height: 96px;

      @include mix.mq(sp) {
        padding: 0 20px;
        height: 72px;
      }
    }

    &__logo {
      display: flex;
      align-items: center;
      flex-shrink: 0;
    }

    &__logoImg {
      height: 75px;
      width: auto;
      display: block;

      @include mix.mq(sp) {
        height: 50px;
      }
    }

    &__navList {
      display: flex;
      align-items: center;
      gap: 0;
    }

    &__navLink {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 96px;
      padding: 0 20px;
      border-bottom: 1px solid transparent;
      transition: border-color var(--duration-base) ease;
    }

    &__navEn {
      font-size: .6875rem;
      letter-spacing: .12em;
      color: var(--mp-color-dark);
    }

    &__navJa {
      font-size: .5625rem;
      letter-spacing: .05em;
      color: rgba(26, 26, 46, .7);
    }

    @media (any-hover: hover) {
      &__navLink:hover {
        border-bottom-color: var(--mp-color-primary);
      }
    }

    // Hamburger
    &__burger {
      position: relative;
      width: 28px;
      height: 20px;
      z-index: calc(var(--z-hamburger) + 1);
    }

    &__burgerLine {
      display: block;
      position: absolute;
      left: 0;
      width: 100%;
      height: 1px;
      background-color: var(--mp-color-dark);
      transition: transform var(--duration-base) ease, opacity var(--duration-base) ease;

      &:nth-child(1) { top: 0; }
      &:nth-child(2) { top: 50%; }
      &:nth-child(3) { bottom: 0; }
    }

    &.is-open &__burgerLine {
      &:nth-child(1) { top: 50%; transform: rotate(45deg); }
      &:nth-child(2) { opacity: 0; }
      &:nth-child(3) { bottom: auto; top: 50%; transform: rotate(-45deg); }
    }

    // SP menu
    // backdrop-filter が新しい包含ブロックを生成するため
    // inset: 0 だけでは親(.MpHeader)基準になる。明示的にサイズ指定で回避。
    &__menu {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100dvh;
      z-index: var(--z-hamburger);
      background-color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--duration-base) ease, visibility var(--duration-base) ease;
    }

    &.is-open &__menu {
      opacity: 1;
      visibility: visible;
    }

    &__menuList {
      display: flex;
      flex-direction: column;
      gap: 32px;
      text-align: center;
    }

    &__menuLink {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    &__menuEn {
      font-size: .875rem;
      letter-spacing: .12em;
      color: rgba(26, 26, 46, .9);
    }

    &__menuJa {
      font-size: .625rem;
      color: rgba(26, 26, 46, .6);
    }
  }
</style>

<script>
  const header = document.querySelector('.js-mp-header');
  const burger = document.querySelector('.js-mp-burger');
  const menuLinks = document.querySelectorAll('.js-mp-menu-link');

  if (burger && header) {
    burger.addEventListener('click', () => {
      const isOpen = header.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', String(isOpen));
      burger.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
      document.querySelector('#mp-sp-menu')?.setAttribute('aria-hidden', String(!isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    menuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        header.classList.remove('is-open');
        burger.setAttribute('aria-expanded', 'false');
        burger.setAttribute('aria-label', 'メニューを開く');
        document.querySelector('#mp-sp-menu')?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }
</script>
