---
import { Image } from 'astro:assets';
import img01 from '../../assets/images/mayproject/img_gallery_01.jpg';
import img02 from '../../assets/images/mayproject/img_gallery_02.jpg';
import img03 from '../../assets/images/mayproject/img_gallery_03.jpg';
import img04 from '../../assets/images/mayproject/img_gallery_04.jpg';
import img05 from '../../assets/images/mayproject/img_gallery_05.jpg';
import img06 from '../../assets/images/mayproject/img_gallery_06.jpg';
import img07 from '../../assets/images/mayproject/img_gallery_07.jpg';
import img08 from '../../assets/images/mayproject/img_gallery_08.jpg';

const slides = [
  { src: img01, alt: 'ギャラリー画像 1' },
  { src: img02, alt: 'ギャラリー画像 2' },
  { src: img03, alt: 'ギャラリー画像 3' },
  { src: img04, alt: 'ギャラリー画像 4' },
  { src: img05, alt: 'ギャラリー画像 5' },
  { src: img06, alt: 'ギャラリー画像 6' },
  { src: img07, alt: 'ギャラリー画像 7' },
  { src: img08, alt: 'ギャラリー画像 8' },
];
---

<section class="MpGallery" id="gallery">
  <div class="MpGallery__header MpGrid">
    <div class="MpGallery__titleBg">GALLERY</div>
    <div class="MpGallery__titleWrap">
      <span class="MpGallery__titleBar"></span>
      <div class="MpGallery__titleGroup">
        <span class="MpGallery__titleEn">GALLERY</span>
        <h2 class="MpGallery__titleJa">画像展示室</h2>
      </div>
    </div>
    <p class="MpGallery__counter pc-only">
      <span class="MpGallery__counterCurrent js-mp-gallery-current">01</span>
      <span class="MpGallery__counterSep">/</span>
      <span class="MpGallery__counterTotal">{String(slides.length).padStart(2, '0')}</span>
    </p>
  </div>

  <div class="MpGallery__bgText pc-only">GALLERY</div>

  <div class="MpGallery__sliderWrap">
    <div class="MpGallery__slider swiper js-mp-gallery-swiper">
      <div class="swiper-wrapper">
        {slides.map((slide, i) => (
          <div class="swiper-slide MpGallery__slide">
            <div class="MpGallery__slideInner">
              <Image
                src={slide.src}
                alt={slide.alt}
                class="MpGallery__slideImg"
                width={480}
                height={600}
              />
              <div class="MpGallery__slideOverlay"></div>
              <span class="MpGallery__slideNum">{String(i + 1).padStart(2, '0')}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="swiper-pagination MpGallery__pagination"></div>
      <button class="MpGallery__arrow MpGallery__arrow--prev js-mp-gallery-prev" type="button" aria-label="前のスライド">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="MpGallery__arrow MpGallery__arrow--next js-mp-gallery-next" type="button" aria-label="次のスライド">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style lang="scss" is:global>
  @use '../../styles/foundation/mixin' as mix;

  .MpGallery {
    background-color: rgba(255, 255, 255, .95);
    padding: 96px 0 80px;
    position: relative;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0 48px;
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
      align-items: flex-end;

      @include mix.mq(sp) {
        margin-bottom: 32px;
      }
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: 0;
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;
      grid-column: 1 / -1;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
      grid-column: 1 / 7;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__counter {
      display: flex;
      align-items: baseline;
      justify-content: flex-end;
      gap: 4px;
      font-family: var(--mp-font-main);
      letter-spacing: .12em;
      color: rgba(26, 26, 46, .3);
      flex-shrink: 0;
      padding-bottom: 4px;
      grid-column: 7 / -1;
    }

    &__counterCurrent {
      font-size: 1.25rem;
      font-weight: 400;
      color: var(--mp-color-primary);
      line-height: 1;
    }

    &__counterSep {
      font-size: .625rem;
      margin: 0 3px;
      color: rgba(26, 26, 46, .2);
    }

    &__counterTotal {
      font-size: .625rem;
      font-weight: 400;
    }

    &__bgText {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: var(--mp-font-main);
      font-size: 8.75rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .03);
      pointer-events: none;
      user-select: none;
      white-space: nowrap;
    }

    // ── Slider ──
    &__sliderWrap {
      position: relative;
      padding: 0 48px;

      @include mix.mq(sp) {
        padding: 0;
      }
    }

    .swiper {
      overflow: hidden;
      padding-bottom: 48px;

      @include mix.mq(sp) {
        padding-bottom: 36px;
      }
    }

    &__slide {
      width: 27% !important;
      overflow: hidden;
      border: 1px solid var(--mp-color-border);
      transition: border-color .4s ease, box-shadow .4s ease;

      @include mix.mq(sp) {
        width: 72% !important;
        border-color: transparent;
      }
    }

    &__slide.swiper-slide-active {
      border-color: var(--mp-color-primary);
      box-shadow: 0 16px 48px rgba(26, 26, 46, .14);

      @include mix.mq(sp) {
        box-shadow: 0 8px 32px rgba(26, 26, 46, .18);
      }
    }

    &__slideInner {
      overflow: hidden;
      position: relative;
    }

    &__slideImg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 4 / 5;
      display: block;
      transition: transform .6s cubic-bezier(.4, 0, .2, 1), filter .5s ease;
    }

    .swiper-slide:not(.swiper-slide-active) &__slideImg {
      @include mix.mq(sp) {
        filter: brightness(.65);
      }
    }

    &__slideOverlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(26, 26, 46, .35) 0%,
        transparent 40%
      );
      pointer-events: none;
      opacity: 0;
      transition: opacity .5s ease;
    }

    .swiper-slide-active &__slideOverlay {
      opacity: 1;
    }

    &__slideNum {
      position: absolute;
      bottom: 12px;
      left: 16px;
      font-family: var(--mp-font-main);
      font-size: .6875rem;
      font-weight: 400;
      letter-spacing: .15em;
      color: rgba(255, 255, 255, .6);
      pointer-events: none;
      opacity: 0;
      transition: opacity .5s ease;

      @include mix.mq(sp) {
        opacity: 1;
        bottom: 8px;
        left: 10px;
        font-size: .625rem;
      }
    }

    .swiper-slide-active &__slideNum {
      opacity: 1;
    }

    // ── Arrows ──
    &__arrow {
      position: absolute;
      top: calc(50% - 24px);
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      background-color: rgba(255, 255, 255, .88);
      border: 1px solid rgba(26, 26, 46, .06);
      border-radius: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      transition: background-color .3s ease, border-color .3s ease, box-shadow .3s ease, color .3s ease;
      box-shadow: 0 1px 6px rgba(26, 26, 46, .04);
      color: rgba(26, 26, 46, .45);

      @media (any-hover: hover) {
        &:hover {
          background-color: var(--mp-color-primary);
          border-color: var(--mp-color-primary);
          box-shadow: 0 4px 16px rgba(232, 115, 42, .2);
          color: #fff;
        }
      }

      @include mix.mq(sp) {
        display: none;
      }

      &--prev {
        left: 0;
      }

      &--next {
        right: 0;
      }
    }

    // Swiper theme color override
    .swiper {
      --swiper-theme-color: var(--mp-color-primary);
      --swiper-pagination-color: var(--mp-color-primary);
    }

    // ── Pagination ──
    &__pagination.swiper-pagination {
      position: relative;
      bottom: auto;
      margin-top: 16px;
    }

    // PC: progressbar
    &__pagination.swiper-pagination-progressbar {
      width: calc(100% - 96px);
      margin-left: auto;
      margin-right: auto;
      height: 1px;
      background-color: rgba(26, 26, 46, .08);
    }

    &__pagination .swiper-pagination-progressbar-fill {
      background-color: var(--mp-color-primary);
      opacity: .6;
      transition: opacity .3s ease;
    }

    .swiper:hover &__pagination .swiper-pagination-progressbar-fill {
      opacity: 1;
    }

    // SP: bullets
    &__pagination.swiper-pagination-bullets {
      width: auto;
      height: auto;
      margin-top: 12px;
      background-color: transparent;
      display: flex;
      justify-content: center;
      gap: 6px;
    }

    &__pagination .swiper-pagination-bullet {
      width: 6px;
      height: 6px;
      background-color: var(--mp-color-border);
      opacity: 1;
      transition: background-color .3s ease, width .3s ease;
      border-radius: 3px;
    }

    &__pagination .swiper-pagination-bullet-active {
      background-color: var(--mp-color-primary);
      width: 20px;
    }
  }

</style>

<script>
  import Swiper from 'swiper';
  import { Autoplay, EffectCoverflow, Pagination, Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-coverflow';
  import 'swiper/css/pagination';

  document.addEventListener('DOMContentLoaded', () => {
    const el = document.querySelector('.js-mp-gallery-swiper') as HTMLElement | null;
    if (!el) return;

    const counterEl = document.querySelector('.js-mp-gallery-current');
    const mql = window.matchMedia('(max-width: 767px)');
    let swiper: Swiper | null = null;

    const shared: Swiper['params'] = {
      modules: [Autoplay, EffectCoverflow, Pagination, Navigation],
      centeredSlides: true,
      loop: true,
      speed: 700,
      autoplay: {
        delay: 4500,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        prevEl: '.js-mp-gallery-prev',
        nextEl: '.js-mp-gallery-next',
      },
    };

    const pcConfig: Swiper['params'] = {
      ...shared,
      effect: 'coverflow',
      slidesPerView: 'auto',
      grabCursor: true,
      coverflowEffect: {
        rotate: 0,
        stretch: 80,
        depth: 200,
        modifier: 1,
        slideShadows: false,
      },
      pagination: {
        el: '.MpGallery__pagination',
        type: 'progressbar',
      },
    };

    const spConfig: Swiper['params'] = {
      ...shared,
      effect: 'coverflow',
      slidesPerView: 'auto',
      grabCursor: false,
      coverflowEffect: {
        rotate: 0,
        stretch: 40,
        depth: 120,
        modifier: 1,
        slideShadows: false,
      },
      pagination: {
        el: '.MpGallery__pagination',
        type: 'bullets',
        clickable: true,
      },
    };

    const updateCounter = () => {
      if (counterEl && swiper) {
        counterEl.textContent = String(swiper.realIndex + 1).padStart(2, '0');
      }
    };

    const paginationEl = el.querySelector('.MpGallery__pagination');

    const createSwiper = (isSp: boolean) => {
      if (swiper) {
        swiper.destroy(true, true);
        swiper = null;
      }
      if (paginationEl) {
        paginationEl.innerHTML = '';
        paginationEl.className = 'swiper-pagination MpGallery__pagination';
      }
      swiper = new Swiper(el, isSp ? spConfig : pcConfig);
      updateCounter();
      swiper.on('slideChange', updateCounter);
    };

    createSwiper(mql.matches);

    mql.addEventListener('change', (e) => {
      createSwiper(e.matches);
    });
  });
</script>
