---
import { publishedMpNewsItems, categoryColors } from '../../data/mp-news';

const newsItems = publishedMpNewsItems.slice(0, 5).map((item) => ({
  date: item.date,
  datetime: item.date.replace(/\./g, '-'),
  category: item.category,
  categoryColor: categoryColors[item.category],
  title: item.title,
  href: `/mayproject/news/${item.slug}/`,
}));
---

<section class="MpNews" id="news">
  <div class="MpNews__inner MpGrid">
    <div class="MpNews__header">
      <div class="MpNews__titleBg">NEWS</div>
      <div class="MpNews__titleWrap">
        <span class="MpNews__titleBar"></span>
        <div class="MpNews__titleGroup">
          <span class="MpNews__titleEn">NEWS</span>
          <h2 class="MpNews__titleJa">お知らせ</h2>
        </div>
      </div>
    </div>

    <ul class="MpNews__list">
      {newsItems.map((item) => (
        <li class="MpNews__item">
          <a href={item.href} class="MpNews__link">
            <time class="MpNews__date" datetime={item.datetime}>{item.date}</time>
            <span
              class="MpNews__badge"
              style={`background-color: ${item.categoryColor}`}
            >
              {item.category}
            </span>
            <span class="MpNews__title">{item.title}</span>
            <span class="MpNews__arrow">&rarr;</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="MpNews__viewAll">
      <a href="/mayproject/news/" class="MpNews__viewAllLink">
        VIEW ALL <span>&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .MpNews {
    background-color: rgba(255, 255, 255, .9);
    padding: 80px 0;
    overflow: hidden;

    @include mix.mq(sp) {
      padding: 56px 0;
    }

    &__header {
      position: relative;
      margin-bottom: 48px;
      grid-column: 3 / 11;
    }

    &__titleBg {
      position: absolute;
      top: -44px;
      left: -12px;
      font-family: var(--mp-font-main);
      font-size: 6.25rem;
      font-weight: 400;
      letter-spacing: .1em;
      color: rgba(232, 115, 42, .05);
      line-height: 1;
      pointer-events: none;
      user-select: none;

      @include mix.mq(sp) {
        font-size: 3.5rem;
        top: -24px;
      }
    }

    &__titleWrap {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    &__titleBar {
      width: 4px;
      height: 48px;
      background-color: var(--mp-color-primary);
      flex-shrink: 0;
    }

    &__titleGroup {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__titleEn {
      font-size: .6875rem;
      letter-spacing: .25em;
      color: var(--mp-color-primary);
    }

    &__titleJa {
      font-family: var(--mp-font-main);
      font-size: 2rem;
      letter-spacing: .08em;
      color: var(--mp-color-dark);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__list {
      display: flex;
      flex-direction: column;
      grid-column: 3 / 11;
    }

    &__item {
      border-bottom: 1px solid var(--mp-color-border);
    }

    &__link {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 17px 12px;
      transition: background-color var(--duration-base) ease;

      @include mix.mq(sp) {
        flex-wrap: wrap;
        gap: 8px;
        padding: 14px 8px;
      }

      @media (any-hover: hover) {
        &:hover {
          background-color: rgba(232, 115, 42, .03);
        }
      }
    }

    &__date {
      font-size: .75rem;
      letter-spacing: .05em;
      color: var(--mp-color-text-light);
      flex-shrink: 0;
      width: 80px;

      @include mix.mq(sp) {
        width: auto;
      }
    }

    &__badge {
      display: inline-block;
      padding: 1px 12px;
      font-size: .625rem;
      letter-spacing: .08em;
      color: #fff;
      flex-shrink: 0;
      margin-right: 16px;

      @include mix.mq(sp) {
        margin-right: 0;
      }
    }

    &__title {
      font-size: .8125rem;
      letter-spacing: .1em;
      color: var(--mp-color-text);
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;

      @include mix.mq(sp) {
        width: 100%;
        flex: none;
        white-space: normal;
      }
    }

    &__arrow {
      font-size: .875rem;
      color: var(--mp-color-text-muted);
      flex-shrink: 0;
      margin-left: auto;
      padding-left: 16px;

      @include mix.mq(sp) {
        display: none;
      }
    }

    &__viewAll {
      display: flex;
      justify-content: flex-end;
      margin-top: 16px;
      grid-column: 3 / 11;
    }

    &__viewAllLink {
      font-size: .75rem;
      letter-spacing: .1em;
      color: rgba(26, 26, 46, .75);
      transition: color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          color: var(--mp-color-primary);
        }
      }
    }
  }
</style>
