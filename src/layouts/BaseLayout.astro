---
import '../styles/global.scss';
import Loading from '../components/Loading.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from 'emdash';
import { createPublicPageContext } from 'emdash/page';
import { EmDashBodyEnd, EmDashBodyStart, EmDashHead } from 'emdash/ui';
import {
  resolveMediaUrl,
  resolveSiteName,
  resolveSiteUrl,
  resolveTagline,
  type SiteSettingsLike,
} from '../site-config';

interface NavItem {
  label: string;
  target?: string | null;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  content?: { collection: string; id: string; slug?: string | null };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  navItems?: NavItem[];
  siteSettings?: SiteSettingsLike | null;
}

const {
  navItems = [],
  siteSettings = null,
  title: titleProp,
  description: descriptionProp,
  canonical = Astro.url.href,
  ogType = 'website',
  ogImage,
  publishedTime,
  modifiedTime,
  author,
  content,
  jsonLd,
} = Astro.props;

const settings = siteSettings ?? await getSiteSettings();
const siteUrl = resolveSiteUrl(settings);
const siteName = resolveSiteName(settings);
const defaultDescription = resolveTagline(settings).replace(/\s+/g, ' ').trim();
const defaultFavicon = resolveMediaUrl(settings?.favicon) ?? '/favicon.svg';
const defaultOgImage = resolveMediaUrl(settings?.seo?.defaultOgImage) ?? '/og-image.png';
const title = titleProp ?? siteName;
const description = descriptionProp ?? defaultDescription;

const resolvedOgImage = ogImage ?? defaultOgImage;
const absoluteOgImage = resolvedOgImage.startsWith('http')
  ? resolvedOgImage
  : new URL(resolvedOgImage, siteUrl).href;
const faviconType = defaultFavicon.endsWith('.svg') ? 'image/svg+xml' : undefined;

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd) ? jsonLd : [jsonLd]
  : [];

const pageCtx = createPublicPageContext({
  Astro,
  kind: content ? 'content' : 'custom',
  pageType: ogType === 'article' ? 'article' : 'website',
  title,
  description,
  canonical,
  image: absoluteOgImage,
  content,
  seo: { ogImage: absoluteOgImage },
  articleMeta: { publishedTime, modifiedTime, author },
  siteName,
});
---

<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no">
    <title>{title}</title>
    <meta name="robots" content="index, follow">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#fcfaf5">
    {settings?.seo?.googleVerification && (
      <meta name="google-site-verification" content={settings.seo.googleVerification}>
    )}
    {settings?.seo?.bingVerification && (
      <meta name="msvalidate.01" content={settings.seo.bingVerification}>
    )}
    <EmDashHead page={pageCtx} />
    {publishedTime && <meta property="article:published_time" content={publishedTime}>}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime}>}

    <link rel="icon" type={faviconType} href={defaultFavicon}>
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">

    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
    ))}

    <slot name="head" />
  </head>
  <body>
    <EmDashBodyStart page={pageCtx} />
    <Loading siteName={siteName} />
    <Header siteName={siteName} navItems={navItems} />
    <main>
      <slot />
    </main>
    <Footer siteName={siteName} />
    <script>
      import '../scripts/dissolve-scroll.ts';
      import '../scripts/scroll-fade.ts';
    </script>
    <EmDashBodyEnd page={pageCtx} />
  </body>
</html>
