---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date.replace(/\./g, '-')).getTime() - new Date(a.data.date.replace(/\./g, '-')).getTime()
);

const siteUrl = 'https://maymai.dev';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog',
  description: 'ブログ記事の一覧です。',
  url: `${siteUrl}/blog/`,
  isPartOf: { '@type': 'WebSite', name: 'Maymai.dev', url: siteUrl },
};
---

<BaseLayout title="Blog | Maymai.dev" description="ブログ記事の一覧です。" jsonLd={jsonLd}>
  <section id="blog" class="BlogPage">
    <div class="BlogPage__inner l-inner">
      <div class="BlogPage__header u-anime">
        <h1 class="BlogPage__heading">Blog</h1>
        <span class="BlogPage__label">// Blog.all()</span>
      </div>

      <ul class="BlogPage__list">
        {sortedPosts.map((post, i) => (
          <li class="BlogPage__item u-anime" style={`--delay: ${i * .06}s;`}>
            <a href={`/blog/${post.id}/`} class="BlogPage__link">
              <div class="BlogPage__thumb">
                <img
                  src={post.data.thumbnail ?? '/og-image.png'}
                  alt={post.data.title}
                  width="1200"
                  height="630"
                  loading="lazy"
                />
              </div>
              <div class="BlogPage__content">
                <time class="BlogPage__date" datetime={post.data.date.replace(/\./g, '-')}>{post.data.date}</time>
                <span class="BlogPage__title">{post.data.title}</span>
                {post.data.description && (
                  <p class="BlogPage__excerpt">{post.data.description}</p>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .BlogPage {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 100px 0 60px;
    }

    &__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 60px;

      @include mix.mq(sp) {
        margin-bottom: 40px;
      }
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 3.2rem;
      line-height: 1.5;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2rem;
      }
    }

    &__label {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      flex-shrink: 0;
    }

    &__list {
      border-top: 1px solid var(--color-border);
    }

    &__item {
      border-bottom: 1px solid var(--color-border);
    }

    &__link {
      display: flex;
      align-items: center;
      gap: 24px;
      padding: 28px 0;
      transition: opacity var(--duration-base) ease;

      @include mix.mq(sp) {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
        padding: 20px 0;
      }

      @media (any-hover: hover) {
        &:hover {
          opacity: .6;
        }
      }
    }

    &__thumb {
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 1200 / 630;
      overflow: hidden;
      border: 1px solid var(--color-border);
      background-color: var(--color-bg);

      @include mix.mq(sp) {
        width: 100%;
      }

      img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }
    }

    &__content {
      min-width: 0;
    }

    &__date {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      white-space: nowrap;
      display: block;
    }

    &__title {
      display: block;
      margin-top: 4px;
      font-size: .875rem;
      line-height: 1.8;
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    &__excerpt {
      margin-top: 4px;
      font-size: .75rem;
      line-height: 1.6;
      color: var(--color-label);
    }
  }
</style>
