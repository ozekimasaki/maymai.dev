---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import LikeButton from '../../components/LikeButton.astro';
import { getEmDashEntry } from 'emdash';
import { CommentForm, Comments, PortableText } from 'emdash/ui';
import { getCachedEntryTerms, getPublicSiteShellData } from '../../public-site-cache';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const [
  { entry: post, cacheHint },
  {
    navItems,
    profile,
    siteName,
    siteSettings: settings,
    siteUrl,
    titleSeparator,
  },
] = await Promise.all([
  getEmDashEntry('blog', slug),
  getPublicSiteShellData(),
]);

if (!post) {
  return Astro.redirect('/404');
}

Astro.cache.set(cacheHint);
const authorName = profile.profileName;
const pageUrl = `${siteUrl}/blog/${post.id}/`;
const isoDate = post.data.date.replace(/\./g, '-');
const tags = await getCachedEntryTerms('blog', post.data.id, 'tag');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: pageUrl,
  datePublished: isoDate,
  author: {
    '@type': 'Person',
    name: authorName,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    name: authorName,
    url: siteUrl,
  },
  inLanguage: 'ja',
  ...(tags.length > 0 && { keywords: tags.map((tag) => tag.label).join(', ') }),
};
---

<BaseLayout
  title={`${post.data.title}${titleSeparator}Blog${titleSeparator}${siteName}`}
  description={post.data.description}
  ogType="article"
  publishedTime={isoDate}
  author={authorName}
  content={{ collection: 'blog', id: post.data.id, slug }}
  jsonLd={jsonLd}
  navItems={navItems}
  siteSettings={settings}
>
  <article class="BlogPost">
    <div class="BlogPost__inner l-inner">
      <div class="BlogPost__header u-anime">
        <time class="BlogPost__date" datetime={post.data.date.replace(/\./g, '-')}>
          {post.data.date}
        </time>
        <h1 class="BlogPost__title">{post.data.title}</h1>
        {tags.length > 0 && (
          <ul class="BlogPost__tags">
            {tags.map((tag) => (
              <li class="BlogPost__tag">
                <a href={`/tag/${tag.slug}/`}>{tag.label}</a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="BlogPost__body u-anime" style="--delay: .1s;">
        {post.data.content ? <PortableText value={post.data.content} /> : <p>準備中です。</p>}
      </div>

      <div class="BlogPost__actions u-anime" style="--delay: .15s;">
        <ShareButtons url={Astro.url.href} title={post.data.title} />
        <LikeButton type="blog" slug={post.id} />
      </div>

      <section class="BlogPost__comments u-anime" style="--delay: .2s;">
        <h2 class="BlogPost__commentsHeading">Comments</h2>
        <Comments collection="blog" contentId={post.data.id} threaded />
        <CommentForm collection="blog" contentId={post.data.id} />
      </section>

      <div class="BlogPost__back">
        <a href="/blog/" class="BlogPost__backLink">&larr; Blog 一覧にもどる</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .BlogPost {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 100px 0 60px;
    }

    &__header {
      max-width: 720px;
      margin-inline: auto;
      margin-bottom: 64px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--color-border);
    }

    &__date {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
    }

    &__title {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 2rem;
      line-height: 1.5;
      margin-top: 16px;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 1.5rem;
      }
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
    }

    &__tag {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      padding: 2px 10px;
      border: 1px solid var(--color-border);

      a {
        color: inherit;
        text-decoration: none;
      }
    }

    &__body {
      max-width: 720px;
      margin-inline: auto;

      :global(h2) {
        font-family: var(--font-heading);
        font-weight: 400;
        font-size: 1.5rem;
        line-height: 1.5;
        margin-top: 48px;
        margin-bottom: 16px;
        color: var(--color-text);
      }

      :global(p) {
        font-size: .875rem;
        line-height: 2;
        margin-bottom: 1.5em;
      }

      :global(ul),
      :global(ol) {
        margin-bottom: 1.5em;
        padding-left: 1.5em;
      }

      :global(ul) {
        list-style: disc;
      }

      :global(ol) {
        list-style: decimal;
      }

      :global(li) {
        font-size: .875rem;
        line-height: 2;
        margin-bottom: .5em;
      }

      :global(strong) {
        font-weight: 500;
      }

      :global(code) {
        font-family: var(--font-mono);
        font-size: .8125rem;
        background-color: var(--color-bg-alt);
        padding: 2px 6px;
        border-radius: 3px;
      }
    }

    &__actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 720px;
      margin-inline: auto;
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid var(--color-border);
    }

    &__comments {
      max-width: 720px;
      margin-inline: auto;
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid var(--color-border);
    }

    &__commentsHeading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 1.5rem;
      line-height: 1.5;
      margin-bottom: 24px;
      color: var(--color-text);
    }

    &__back {
      max-width: 720px;
      margin-inline: auto;
      margin-top: 64px;
      padding-top: 32px;
      border-top: 1px solid var(--color-border);
    }

    &__backLink {
      font-family: var(--font-mono);
      font-size: .75rem;
      color: var(--color-label);
      transition: color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          color: var(--color-text);
        }
      }
    }
  }
</style>
