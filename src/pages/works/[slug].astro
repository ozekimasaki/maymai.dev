---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<BaseLayout
  title={`${work.data.title} | Works | Maymai.dev`}
  description={work.data.description}
  ogType="article"
>
  <article class="WorkDetail">
    <div class="WorkDetail__inner l-inner">
      <div class="WorkDetail__header">
        <p class="WorkDetail__category">{work.data.category}</p>
        <h1 class="WorkDetail__title">{work.data.title}</h1>
        <p class="WorkDetail__description">{work.data.description}</p>
      </div>

      <div class="WorkDetail__meta">
        <div class="WorkDetail__metaItem">
          <dt class="WorkDetail__metaKey">date:</dt>
          <dd class="WorkDetail__metaValue">{work.data.date}</dd>
        </div>
        <div class="WorkDetail__metaItem">
          <dt class="WorkDetail__metaKey">technologies:</dt>
          <dd class="WorkDetail__metaValue">{work.data.technologies.join(' / ')}</dd>
        </div>
      </div>

      <div class="WorkDetail__thumbnail">
        <img
          src={work.data.thumbnail}
          alt={work.data.title}
          width="1182"
          height="680"
        />
      </div>

      <div class="WorkDetail__body">
        <Content />
      </div>

      <div class="WorkDetail__back">
        <a href="/works/" class="WorkDetail__backLink">&larr; Works 一覧にもどる</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .WorkDetail {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 100px 0 60px;
    }

    &__header {
      margin-bottom: 48px;
    }

    &__category {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      margin-bottom: 12px;
    }

    &__title {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 2.5rem;
      line-height: 1.4;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 1.75rem;
      }
    }

    &__description {
      margin-top: 16px;
      font-size: .875rem;
      line-height: 1.8;
      color: var(--color-label);
    }

    &__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 32px;
      padding: 24px 0;
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 48px;

      @include mix.mq(sp) {
        flex-direction: column;
        gap: 16px;
      }
    }

    &__metaItem {
      display: flex;
      align-items: baseline;
      gap: 12px;
    }

    &__metaKey {
      font-family: var(--font-mono);
      font-size: .625rem;
      color: var(--color-label);
      flex-shrink: 0;
    }

    &__metaValue {
      font-family: var(--font-heading);
      font-size: .875rem;
      line-height: 1.5;
      color: var(--color-text);
    }

    &__thumbnail {
      margin-bottom: 64px;

      img {
        width: 100%;
        height: auto;
        aspect-ratio: 1182 / 680;
        object-fit: cover;
      }
    }

    &__body {
      max-width: 720px;
      margin-inline: auto;

      :global(h2) {
        font-family: var(--font-heading);
        font-weight: 400;
        font-size: 1.5rem;
        line-height: 1.5;
        margin-top: 48px;
        margin-bottom: 16px;
        color: var(--color-text);
      }

      :global(p) {
        font-size: .875rem;
        line-height: 2;
        margin-bottom: 1.5em;
      }

      :global(ul),
      :global(ol) {
        margin-bottom: 1.5em;
        padding-left: 1.5em;
        list-style: disc;
      }

      :global(li) {
        font-size: .875rem;
        line-height: 2;
        margin-bottom: .5em;
      }
    }

    &__back {
      margin-top: 64px;
      padding-top: 32px;
      border-top: 1px solid var(--color-border);
    }

    &__backLink {
      font-family: var(--font-mono);
      font-size: .75rem;
      color: var(--color-label);
      transition: color var(--duration-base) ease;

      @media (any-hover: hover) {
        &:hover {
          color: var(--color-text);
        }
      }
    }
  }
</style>
