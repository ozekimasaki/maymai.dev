---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import WorksSection from '../components/sections/WorksSection.astro';
import BlogSection from '../components/sections/BlogSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import { getCachedHomePosts, getCachedHomeWorks, getPublicSiteShellData } from '../public-site-cache';

const [
  {
    navItems,
    profile,
    sameAs,
    siteName,
    siteSettings: settings,
    siteUrl,
    socialLinks,
    tagline,
    titleSeparator,
  },
  worksWithCategories,
  posts,
] = await Promise.all([
  getPublicSiteShellData(),
  getCachedHomeWorks(),
  getCachedHomePosts(),
]);
const siteDescription = tagline.replace(/\s+/g, ' ').trim();
const personDescription = profile.aboutParagraphs[0] ?? siteDescription;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl,
    description: siteDescription,
    inLanguage: 'ja',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: profile.profileName,
    alternateName: profile.profileAlias,
    url: siteUrl,
    jobTitle: profile.profileRole,
    description: personDescription,
    sameAs,
    knowsAbout: [
      'TypeScript', 'JavaScript', 'Astro', 'React', 'SCSS',
      'Cloudflare Workers', 'Vite', 'AI-assisted development',
    ],
  },
];
---

<BaseLayout
  title={`${siteName}${titleSeparator}${profile.profileRole}`}
  description={siteDescription}
  jsonLd={jsonLd}
  navItems={navItems}
  siteSettings={settings}
>
  <HeroSection
    label={profile.heroLabel}
    headingLine1={profile.heroHeadingLine1}
    headingLine2={profile.heroHeadingLine2}
    description={tagline}
  />
  <AboutSection
    profileName={profile.profileName}
    profileRole={profile.profileRole}
    basedIn={profile.basedIn}
    philosophy={profile.philosophy}
    aboutParagraphs={profile.aboutParagraphs}
  />
  <SkillsSection skillGroups={profile.skillGroups} />
  <WorksSection works={worksWithCategories} />
  <BlogSection posts={posts} />
  <ContactSection description={profile.contactDescription} links={socialLinks} />
</BaseLayout>
