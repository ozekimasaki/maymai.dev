---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCachedTaxonomyTerms, getCachedWorksByCategory, getPublicSiteShellData } from '../../public-site-cache';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const [allCategories, { navItems, siteName, siteSettings: settings, titleSeparator }] = await Promise.all([
  getCachedTaxonomyTerms('category'),
  getPublicSiteShellData(),
]);
const category = allCategories.find((term) => term.slug === slug);

if (!category) {
  return Astro.redirect('/404');
}

const works = await getCachedWorksByCategory(category.slug);
---

<BaseLayout
  title={`${category.label}${titleSeparator}Works${titleSeparator}${siteName}`}
  description={`${category.label} の制作実績一覧です。`}
  navItems={navItems}
  siteSettings={settings}
>
  <section id="category" class="CategoryPage">
    <div class="CategoryPage__inner l-inner">
      <div class="CategoryPage__header u-anime">
        <h1 class="CategoryPage__heading">{category.label}</h1>
        <span class="CategoryPage__label">// category:{category.slug}</span>
      </div>

      <div class="CategoryPage__grid">
        {works.map((work, i) => (
          <a href={`/works/${work.id}/`} class="CategoryPage__card u-anime" style={`--delay: ${i * .1}s;`}>
            <div class="CategoryPage__cardImage">
              <img
                src={work.thumbnail}
                alt={work.title}
                width="580"
                height="360"
                loading="lazy"
              />
            </div>
            <div class="CategoryPage__cardInfo">
              <h2 class="CategoryPage__cardTitle">{work.title}</h2>
              <p class="CategoryPage__cardDescription">{work.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .CategoryPage {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 100px 0 60px;
    }

    &__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 60px;

      @include mix.mq(sp) {
        margin-bottom: 40px;
      }
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 3.2rem;
      line-height: 1.5;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2rem;
      }
    }

    &__label {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      flex-shrink: 0;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 48px 16px;

      @include mix.mq(sp) {
        grid-template-columns: 1fr;
        gap: 40px;
      }
    }

    &__card {
      display: block;

      img {
        width: 100%;
        height: auto;
        aspect-ratio: 580 / 360;
        object-fit: cover;
        transition: transform var(--duration-base) ease;
      }

      @media (any-hover: hover) {
        &:hover img {
          transform: scale(1.03);
        }
      }
    }

    &__cardImage {
      overflow: hidden;
    }

    &__cardInfo {
      margin-top: 16px;
    }

    &__cardTitle {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 1.25rem;
      line-height: 1.5;
      color: var(--color-text);
    }

    &__cardDescription {
      margin-top: 8px;
      font-size: .8125rem;
      line-height: 1.8;
      color: var(--color-label);
    }
  }
</style>
