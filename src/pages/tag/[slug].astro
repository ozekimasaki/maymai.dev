---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEmDashCollection, getTaxonomyTerms } from 'emdash';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const tag = (await getTaxonomyTerms('tag')).find((term) => term.slug === slug);

if (!tag) {
  return Astro.redirect('/404');
}

const { entries: allPosts, cacheHint } = await getEmDashCollection('blog', {
  where: { tag: tag.slug },
});

try {
  Astro.cache.set(cacheHint);
} catch {}

const posts = [...allPosts].sort(
  (a, b) =>
    new Date(b.data.date.replace(/\./g, '-')).getTime() -
    new Date(a.data.date.replace(/\./g, '-')).getTime()
);
---

<BaseLayout title={`#${tag.label} | Blog | Maymai.dev`} description={`${tag.label} の記事一覧です。`}>
  <section id="tag" class="TagPage">
    <div class="TagPage__inner l-inner">
      <div class="TagPage__header u-anime">
        <h1 class="TagPage__heading">#{tag.label}</h1>
        <span class="TagPage__label">// tag:{tag.slug}</span>
      </div>

      <ul class="TagPage__list">
        {posts.map((post, i) => (
          <li class="TagPage__item u-anime" style={`--delay: ${i * .06}s;`}>
            <a href={`/blog/${post.id}/`} class="TagPage__link">
              <time class="TagPage__date" datetime={post.data.date.replace(/\./g, '-')}>
                {post.data.date}
              </time>
              <div class="TagPage__content">
                <span class="TagPage__title">{post.data.title}</span>
                {post.data.description && <p class="TagPage__excerpt">{post.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/foundation/mixin' as mix;

  .TagPage {
    padding: 128px 0 80px;

    @include mix.mq(sp) {
      padding: 100px 0 60px;
    }

    &__header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 60px;

      @include mix.mq(sp) {
        margin-bottom: 40px;
      }
    }

    &__heading {
      font-family: var(--font-heading);
      font-weight: 400;
      font-size: 3.2rem;
      line-height: 1.5;
      color: var(--color-text);

      @include mix.mq(sp) {
        font-size: 2rem;
      }
    }

    &__label {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      flex-shrink: 0;
    }

    &__list {
      border-top: 1px solid var(--color-border);
    }

    &__item {
      border-bottom: 1px solid var(--color-border);
    }

    &__link {
      display: flex;
      align-items: baseline;
      gap: 40px;
      padding: 28px 0;
      transition: opacity var(--duration-base) ease;

      @include mix.mq(sp) {
        flex-direction: column;
        gap: 8px;
        padding: 20px 0;
      }

      @media (any-hover: hover) {
        &:hover {
          opacity: .6;
        }
      }
    }

    &__date {
      font-family: var(--font-mono);
      font-size: .625rem;
      line-height: 1.5;
      color: var(--color-label);
      flex-shrink: 0;
      white-space: nowrap;
    }

    &__title {
      font-size: .875rem;
      line-height: 1.8;
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    &__excerpt {
      margin-top: 4px;
      font-size: .75rem;
      line-height: 1.6;
      color: var(--color-label);
    }
  }
</style>
